@page "/tts"
@using ArkPlot.Tts
@inject ITtsEngine TtsEngine
@inject VoiceManager Voices
@implements IDisposable

<PageTitle>ArkPlot - TTS 测试</PageTitle>

<h3><i class="bi bi-volume-up"></i> EdgeTTS 测试面板</h3>
<hr />

@* 单句合成 *@
<div class="card mb-4">
    <div class="card-header"><strong>单句合成</strong></div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">文本</label>
            <textarea class="form-control" rows="3" @bind="singleText" placeholder="输入要合成的文本…"></textarea>
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">音色</label>
                <select class="form-select" @bind="selectedVoice">
                    <option value="zh-CN-XiaoxiaoNeural">Xiaoxiao（温暖·女）</option>
                    <option value="zh-CN-XiaoyiNeural">Xiaoyi（活泼·女）</option>
                    <option value="zh-CN-liaoning-XiaobeiNeural">Xiaobei（幽默·女）</option>
                    <option value="zh-TW-HsiaoChenNeural">HsiaoChen（台湾·女）</option>
                    <option value="zh-TW-HsiaoYuNeural">HsiaoYu（台湾·女）</option>
                    <option value="zh-CN-YunxiNeural">Yunxi（阳光·男）</option>
                    <option value="zh-CN-YunjianNeural">Yunjian（激情·男）</option>
                    <option value="zh-CN-YunxiaNeural">Yunxia（可爱·男）</option>
                    <option value="zh-CN-YunyangNeural">Yunyang（专业·男）</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">语速</label>
                <select class="form-select" @bind="rate">
                    <option value="-20%">-20%（慢）</option>
                    <option value="-10%">-10%</option>
                    <option value="+0%">+0%（默认）</option>
                    <option value="+10%">+10%</option>
                    <option value="+20%">+20%（快）</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">音量</label>
                <select class="form-select" @bind="volume">
                    <option value="-20%">-20%（低）</option>
                    <option value="-10%">-10%</option>
                    <option value="+0%">+0%（默认）</option>
                    <option value="+10%">+10%</option>
                    <option value="+20%">+20%（高）</option>
                </select>
            </div>
        </div>
        <button class="btn btn-primary" @onclick="SynthesizeSingle" disabled="@isBusy">
            @(isBusy ? "合成中…" : "🎤 合成")
        </button>
    </div>
</div>

@* 角色音色分配 *@
<div class="card mb-4">
    <div class="card-header"><strong>角色音色分配</strong></div>
    <div class="card-body">
        <div class="input-group mb-3">
            <input class="form-control" @bind="characterName" placeholder="输入角色名，查看自动分配的音色" />
            <button class="btn btn-outline-secondary" @onclick="LookupVoice">查询</button>
        </div>
        @if (!string.IsNullOrEmpty(voiceResult))
        {
            <div class="alert alert-info">@voiceResult</div>
        }
    </div>
</div>

@* 日志 & 播放 *@
@if (!string.IsNullOrEmpty(audioUrl))
{
    <div class="card mb-4 border-success">
        <div class="card-header bg-success text-white"><strong>✅ 音频播放</strong></div>
        <div class="card-body">
            <audio controls src="@audioUrl" class="w-100"></audio>
            <a href="@audioUrl" download class="btn btn-sm btn-outline-success mt-2">⬇ 下载</a>
        </div>
    </div>
}

@if (logs.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header"><strong>📋 日志</strong></div>
        <div class="card-body">
            <pre class="mb-0" style="max-height:400px;overflow:auto;white-space:pre-wrap">@string.Join("\n", logs)</pre>
        </div>
    </div>
}

@code {
    private string singleText = "你好，这是 EdgeTTS 的测试语音。希望你能听到清晰自然的中文发音。";
    private string selectedVoice = "zh-CN-XiaoxiaoNeural";
    private string rate = "+0%";
    private string volume = "+0%";
    private string characterName = "";
    private string voiceResult = "";
    private string? audioUrl;
    private bool isBusy;
    private readonly List<string> logs = new();

    private string AudioDir => Path.Combine(
        Directory.GetCurrentDirectory(), "wwwroot", "audio");

    protected override void OnInitialized()
    {
        Directory.CreateDirectory(AudioDir);
    }

    private void Log(string msg)
    {
        logs.Insert(0, $"[{DateTime.Now:HH:mm:ss}] {msg}");
    }

    private async Task SynthesizeSingle()
    {
        if (string.IsNullOrWhiteSpace(singleText)) return;
        isBusy = true;
        audioUrl = null;
        StateHasChanged();

        try
        {
            var fileName = $"single_{DateTime.Now:yyyyMMddHHmmss}.mp3";
            var outputPath = Path.Combine(AudioDir, fileName);

            Log($"开始合成: 音色={selectedVoice}, 语速={rate}, 音量={volume}");
            Log($"文本: {singleText}");

            await TtsEngine.SynthesizeAsync(singleText, selectedVoice, outputPath, rate, volume);

            audioUrl = $"audio/{fileName}";
            Log($"✅ 合成完成: {fileName}");
        }
        catch (Exception ex)
        {
            Log($"❌ 错误: {ex.Message}");
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private void LookupVoice()
    {
        if (string.IsNullOrWhiteSpace(characterName)) return;
        var voice = Voices.GetVoiceForCharacter(characterName);
        voiceResult = $"角色「{characterName}」→ 音色: {voice}";
        Log(voiceResult);
    }

    public void Dispose() { }
}
