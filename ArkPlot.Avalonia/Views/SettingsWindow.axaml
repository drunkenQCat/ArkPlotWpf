<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArkPlot.Avalonia.ViewModels;assembly=ArkPlot.Avalonia"
        xmlns:b="clr-namespace:Avalonia.Xaml.Behaviors;assembly=Avalonia.Xaml.Behaviors"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ArkPlot.Avalonia.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="设置" Height="700" Width="600">
    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>
    <i:Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadSettingsCommand}" />
        </EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Tab 1: 标签替换 -->
            <TabItem Header="标签替换">
                <StackPanel Margin="8">
                    <DataGrid Height="400"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        SelectionMode="Extended"
                        SelectedIndex="{Binding SelectedIndex}"
                        ItemsSource="{Binding DataGrid}"
                        AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="tag名" Binding="{Binding Tag}" Width="130"/>
                            <DataGridTextColumn Header="替换为..." Binding="{Binding NewTag}" Width="130"/>
                            <DataGridTextColumn Header="保留内容格式（正则表达式）" Binding="{Binding Reg}" Width="226"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Width="73" Command="{Binding AddItemCommand}" Margin="0,6,0,0">[    +    ]</Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,0">
                        <Button Width="100" Command="{Binding SaveTagJsonCommand}" Content="保存标签" Margin="0,0,10,0"/>
                        <Button Width="80"
                                Command="{Binding CloseWindowCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                Content="关闭"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Tab 2: 小说化设置 -->
            <TabItem Header="小说化设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Spacing="10">
                        <TextBlock Text="系统提示词（System Prompt）" FontWeight="Bold" FontSize="14"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="180">
                            <TextBox Text="{Binding SystemPromptText}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <Button Command="{Binding RestoreDefaultPromptCommand}"
                                Content="恢复默认提示词"
                                HorizontalAlignment="Left"
                                Padding="12,4"/>

                        <Separator Margin="0,5"/>

                        <TextBlock Text="API Key 配置" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="优先使用此处的值；如为空，则读取环境变量" FontSize="11" Foreground="Gray"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="DeepSeek API Key" FontSize="12"/>
                            <TextBox Text="{Binding DeepSeekApiKeyText}"
                                     PasswordChar="•"
                                     Watermark="留空则使用 DEEPSEEK_API_KEY 环境变量"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="百炼 API Key" FontSize="12"/>
                            <TextBox Text="{Binding BailianApiKeyText}"
                                     PasswordChar="•"
                                     Watermark="留空则使用 DASHSCOPE_API_KEY 环境变量"/>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="平台选择" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding SelectedProvider}"
                                          Width="160"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="模型选择" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding ModelOptions}"
                                          SelectedItem="{Binding SelectedModel}"
                                          Width="200"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <!-- 自定义平台管理 -->
                        <Expander Header="自定义平台管理" IsExpanded="False">
                            <StackPanel Spacing="6" Margin="4">
                                <ListBox ItemsSource="{Binding CustomProviderList}"
                                         SelectedIndex="{Binding SelectedCustomProviderIndex}"
                                         Height="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding Name}"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding BaseUrl}" Foreground="Gray"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Spacing="4">
                                    <TextBox Text="{Binding EditingProviderName}" Watermark="平台名称"/>
                                    <TextBox Text="{Binding EditingProviderUrl}" Watermark="API Base URL（如 https://openrouter.ai/api/v1）"/>
                                    <TextBox Text="{Binding EditingProviderKey}" PasswordChar="•" Watermark="API Key"/>
                                    <TextBox Text="{Binding EditingProviderModelsText}" Watermark="模型列表（逗号分隔，如 gpt-4o,claude-3.5-sonnet）"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding AddCustomProviderCommand}" Content="添加" Padding="12,4"/>
                                    <Button Command="{Binding UpdateCustomProviderCommand}" Content="更新" Padding="12,4"/>
                                    <Button Command="{Binding DeleteCustomProviderCommand}" Content="删除" Padding="12,4" Foreground="#E53935"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Width="100" Command="{Binding SaveNovelizerSettingsCommand}" Content="保存设置" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding SaveFeedbackText}"
                                       VerticalAlignment="Center"
                                       Foreground="#4CAF50"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,10">
                            <Button Width="80"
                                    Command="{Binding CloseWindowCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                    Content="关闭"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: 图片描述设置 -->
            <TabItem Header="图片描述设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Spacing="10">
                        <TextBlock Text="系统提示词（System Prompt）" FontWeight="Bold" FontSize="14"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="150">
                            <TextBox Text="{Binding VisionSystemPrompt}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <Button Command="{Binding RestoreDefaultVisionPromptCommand}"
                                Content="恢复默认提示词"
                                HorizontalAlignment="Left"
                                Padding="12,4"/>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="平台选择" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding VisionProviderOptions}"
                                          SelectedItem="{Binding VisionSelectedProvider}"
                                          Width="160"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="模型选择" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding VisionModelOptions}"
                                          SelectedItem="{Binding VisionSelectedModel}"
                                          Width="200"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsOllamaProvider}">
                            <TextBlock Text="Ollama 服务地址" FontSize="12"/>
                            <TextBox Text="{Binding VisionOllamaBaseUrl}" Watermark="http://localhost:11434"/>
                        </StackPanel>

                        <Separator Margin="0,5"/>

                        <!-- 自定义平台管理 -->
                        <Expander Header="自定义平台管理" IsExpanded="False">
                            <StackPanel Spacing="6" Margin="4">
                                <ListBox ItemsSource="{Binding VisionCustomProviderList}"
                                         SelectedIndex="{Binding VisionSelectedCustomProviderIndex}"
                                         Height="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding Name}"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding BaseUrl}" Foreground="Gray"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Spacing="4">
                                    <TextBox Text="{Binding VisionEditingProviderName}" Watermark="平台名称"/>
                                    <TextBox Text="{Binding VisionEditingProviderUrl}" Watermark="API Base URL"/>
                                    <TextBox Text="{Binding VisionEditingProviderKey}" PasswordChar="•" Watermark="API Key"/>
                                    <TextBox Text="{Binding VisionEditingProviderModelsText}" Watermark="模型列表（逗号分隔）"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding AddVisionCustomProviderCommand}" Content="添加" Padding="12,4"/>
                                    <Button Command="{Binding UpdateVisionCustomProviderCommand}" Content="更新" Padding="12,4"/>
                                    <Button Command="{Binding DeleteVisionCustomProviderCommand}" Content="删除" Padding="12,4" Foreground="#E53935"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Separator Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Width="100" Command="{Binding SaveVisionSettingsCommand}" Content="保存设置" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding VisionSaveFeedbackText}"
                                       VerticalAlignment="Center"
                                       Foreground="#4CAF50"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,10">
                            <Button Width="80"
                                    Command="{Binding CloseWindowCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                    Content="关闭"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: 数据管理 -->
            <TabItem Header="数据管理">
                <StackPanel Margin="16" Spacing="16">
                    <TextBlock Text="数据源同步" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="从 GitHub 和 PRTS Wiki 获取最新数据。强制刷新会无视缓存状态，重新下载并增量更新。"
                               TextWrapping="Wrap" Foreground="Gray"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="语言：" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="120"/>
                    </StackPanel>

                    <Button Content="强制刷新数据"
                            Command="{Binding ForceRefreshDataCommand}"
                            IsEnabled="{Binding !IsDataOperationRunning}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            Classes="Accent"/>

                    <Separator Margin="0,8"/>

                    <TextBlock Text="危险区域" FontWeight="Bold" FontSize="16" Foreground="#E53935"/>
                    <TextBlock Text="清空数据库中所有缓存数据，包括活动列表、章节内容、PRTS 资源索引等。操作不可撤销。"
                               TextWrapping="Wrap" Foreground="Gray"/>

                    <Button Content="清空全部数据"
                            Command="{Binding ResetAllDataCommand}"
                            IsEnabled="{Binding !IsDataOperationRunning}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            Foreground="#E53935"
                            BorderBrush="#E53935"/>

                    <TextBlock Text="{Binding DataManagementStatus}"
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
