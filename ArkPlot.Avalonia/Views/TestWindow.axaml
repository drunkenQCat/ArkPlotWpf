<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ArkPlot.Avalonia.Views"
    xmlns:testViews="using:ArkPlot.Avalonia.Views.Test"
    xmlns:sukiUi="using:SukiUI.Controls"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
    x:Class="ArkPlot.Avalonia.Views.TestWindow"
    Title="ArkPlot 测试面板"
    Width="800" Height="600">

  <TabControl Margin="16">
    <!-- PortraitPanel 测试 -->
    <TabItem Header="立绘组件">
      <testViews:PortraitTestPanel x:Name="PortraitTestTab"/>
    </TabItem>

    <!-- 音频播放测试 -->
    <TabItem Header="音频播放">
      <testViews:AudioTestPanel x:Name="AudioTestTab"/>
    </TabItem>

    <!-- 未来可加更多 Tab -->
    <TabItem Header="Gallery (待做)" IsEnabled="False">
      <TextBlock Text="GalleryPanel 测试待实现" Margin="16" Opacity="0.5"/>
    </TabItem>
  </TabControl>
</sukiUi:SukiWindow>
