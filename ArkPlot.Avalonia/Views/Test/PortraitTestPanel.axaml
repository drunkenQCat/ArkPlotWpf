<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArkPlot.Avalonia.ViewModels.Test"
             xmlns:views="using:ArkPlot.Avalonia.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="ArkPlot.Avalonia.Views.Test.PortraitTestPanel"
             x:DataType="vm:PortraitTestViewModel">
  <Grid ColumnDefinitions="*,*" Margin="8">
    <!-- 左侧：组件展示 -->
    <Border Grid.Column="0" BorderBrush="#30FFFFFF" BorderThickness="1"
            CornerRadius="8" Margin="0,0,8,0">
      <views:PortraitPanel DataContext="{Binding Panel}"
                           Margin="8"/>
    </Border>

    <!-- 右侧：控制面板 -->
    <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
      <TextBlock Text="立绘 URL" FontSize="12" Opacity="0.6"/>
      <TextBox Text="{Binding Panel.PortraitUrl}"
               Watermark="https://media.prts.wiki/..."/>

      <TextBlock Text="角色名" FontSize="12" Opacity="0.6"/>
      <TextBox Text="{Binding Panel.SpeakerName}"
               Watermark="阿米娅"/>

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="加载示例立绘"
                Command="{Binding LoadSampleCommand}"
                Classes="Rounded Accent"/>
        <Button Content="清空"
                Command="{Binding ClearCommand}"
                Classes="Rounded"/>
      </StackPanel>

      <Border BorderBrush="#20FFFFFF" BorderThickness="1"
              CornerRadius="4" Margin="0,8,0,0" Padding="8">
        <StackPanel Spacing="4">
          <TextBlock Text="当前状态" FontSize="12" FontWeight="SemiBold"/>
          <TextBlock>
            <Run Text="HasPortrait: "/>
            <Run Text="{Binding Panel.HasPortrait}"/>
          </TextBlock>
          <TextBlock TextTrimming="CharacterEllipsis">
            <Run Text="URL: "/>
            <Run Text="{Binding Panel.PortraitUrl}"/>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
